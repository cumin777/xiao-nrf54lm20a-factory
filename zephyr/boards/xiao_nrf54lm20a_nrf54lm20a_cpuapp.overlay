&gpio3 {
	status = "okay";
};

&uart21 {
	current-speed = <115200>;
	status = "okay";
};

&uart20 {
	current-speed = <115200>;
	status = "okay";
};

&pmic_i2c {
	sda-gpios = <&gpio1 18 GPIO_ACTIVE_HIGH>;
	scl-gpios = <&gpio1 17 GPIO_ACTIVE_HIGH>;
	status = "okay";
};

&pmic {
	regulators {
		imu_vdd: dmic_vdd: LDO1 {
			regulator-min-microvolt = <3300000>;
			regulator-max-microvolt = <3300000>;
			regulator-boot-on;
		};
	};
};

/*
 * Override charger settings:
 * - Disable NTC thermistor monitoring (thermistor-ohms = 0) so the charger
 *   will not block charging when no physical NTC is present on the board.
 *   When thermistor_idx == 0 the Zephyr driver sets the DISABLENTC bit in
 *   BCHGDISABLESET (CHGR base 0x03, offset 0x06, bit 1).
 * - Raise charge current to 500 mA (factory test only; adjust per battery).
 * - Raise VBUS input limit to 1500 mA so the charger can draw enough current.
 */
&pmic_charger {
	thermistor-ohms = <0>;
	thermistor-beta = <3380>;
	current-microamp = <500000>;
	vbus-limit-microamp = <1500000>;
};

dmic_dev: &pdm20 {
	status = "okay";
};

&py25q64 {
	status = "okay";
};

&lsm6ds3tr_c {
	zephyr,deferred-init;
};

/ {
	aliases {
		regulator-parent = &{/pmic-i2c/npm1300@6b/regulators};
	};

	chosen {
		zephyr,bt-hci = &bt_hci_controller;
	};

	zephyr,user {
		io-channels = <&adc 0>, <&adc 1>, <&adc 2>, <&adc 3>,
			      <&adc 4>, <&adc 5>, <&adc 6>, <&adc 7>;
		/* GPIO loop pairs: D11->D18, D12->D17, D13->D16 */
		gpio-loop-gpios = <&gpio3 0 GPIO_ACTIVE_HIGH>, <&gpio3 7 GPIO_ACTIVE_HIGH>,
				  <&gpio3 1 GPIO_ACTIVE_HIGH>, <&gpio3 6 GPIO_ACTIVE_HIGH>,
				  <&gpio3 2 GPIO_ACTIVE_HIGH>, <&gpio3 5 GPIO_ACTIVE_HIGH>;
		/* NFC loop pairs: D14->NFC1, D15->NFC2 */
		nfc-loop-gpios = <&gpio3 3 GPIO_ACTIVE_HIGH>, <&gpio3 4 GPIO_ACTIVE_HIGH>,
				 <&gpio1 1 GPIO_ACTIVE_HIGH>, <&gpio1 2 GPIO_ACTIVE_HIGH>;
	};
};

/* Passive buzzer on D0 (gpio1 pin 0) via PWM21 channel 0 */
&pinctrl {
	pwm21_default: pwm21_default {
		group1 {
			psels = <NRF_PSEL(PWM_OUT0, 1, 0)>;
		};
	};
	pwm21_sleep: pwm21_sleep {
		group1 {
			psels = <NRF_PSEL(PWM_OUT0, 1, 0)>;
			low-power-enable;
		};
	};
};

&pwm21 {
	status = "okay";
	pinctrl-0 = <&pwm21_default>;
	pinctrl-1 = <&pwm21_sleep>;
	pinctrl-names = "default", "sleep";
};

&bt_hci_controller {
	status = "okay";
};

&bt_hci_sdc {
	status = "disabled";
};
